# Databricks (Learner Edition SQL Warehouse)
DATABRICKS_HOST=                    # e.g., dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_TOKEN=                   # Personal access token
DATABRICKS_HTTP_PATH=               # SQL Warehouse HTTP path: /sql/1.0/warehouses/xxxxx
DATABRICKS_CATALOG=workspace      # Unity Catalog. Use 'hive_metastore' only on legacy/non-UC workspaces.
DATABRICKS_SCHEMA_RAW=raw
DATABRICKS_SCHEMA_STAGING=staging
DATABRICKS_SCHEMA_MARTS=marts

# API Keys
COINGECKO_API_KEY=                  # Free demo key
ETHERSCAN_API_KEY=                  # Free key
# DeFi Llama requires no key

# Neo4j AuraDB Free
NEO4J_URI=                          # neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=                     # Generated on instance creation

# Anthropic
ANTHROPIC_API_KEY=

# Slack
SLACK_WEBHOOK_URL=                  # Incoming Webhook for alerts
SLACK_BOT_TOKEN=                    # Bot User OAuth Token
SLACK_BOT_CHANNEL=                  # Channel for market summaries

# GitHub
GITHUB_TOKEN=                       # PAT with repo scope
GITHUB_REPO=                        # owner/repo format
